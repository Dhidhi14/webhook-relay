PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/webhookrelay
JWT_SECRET=change-this-to-a-random-string-at-least-32-chars
JWT_EXPIRES=7d
REDIS_URL=redis://localhost:6379
BACKOFF_DELAY_MS=30000

